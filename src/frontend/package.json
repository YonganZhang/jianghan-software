{
  "name": "sinopec-system",
  "version": "1.0.0",
  "description": "Sinopec System Application",
  "author": "Sinopec",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "npm run build && electron ."
  },
  "build": {
    "appId": "com.sinopec.system",
    "productName": "Sinopec System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "electron",
      "node_modules",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": "../backend/dist/backend",
        "to": "backend"
      },
      {
        "from": "../backend/resources/julia",
        "to": "julia"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "ant-design-vue": "^4.0.0",
    "axios": "^1.6.0",
    "echarts": "^5.4.3",
    "mitt": "^3.0.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.2",
    "vite": "^5.0.0",
    "vue-tsc": "^3.0.5",
    "wait-on": "^7.2.0"
  }
}